@model IEnumerable<Proyecto_Programacion_III.Models.Entidades.Agendamentos>

<h2>Pagamentos</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Cliente</th>
            <th>Serviço</th>
            <th>Data</th>
            <th>Status Pagamento</th>
            <th>Ação</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Cliente?.NomeCompleto</td>
                <td>@item.Servicos?.Nome</td>
                <td>@item.Data.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    <span class="btn btn-sm @(item.EstadoPagamento == EstadoPagamento.Pago ? "btn-success" : "btn-warning")" style="cursor:default;">
                        @item.EstadoPagamento
                    </span>
                </td>
                <td>
                    <form asp-action="AlterarStatus" method="post">
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="hidden" name="novoStatus"
                               value="@(item.EstadoPagamento == EstadoPagamento.Pago ? EstadoPagamento.Pendente : EstadoPagamento.Pago)" />
                        <button type="submit" class="btn btn-sm btn-primary">
                            Marcar como @(item.EstadoPagamento == EstadoPagamento.Pago ? "Pendente" : "Pago")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>