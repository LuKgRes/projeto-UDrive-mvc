<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Proyecto_Programacion_III</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Proyecto_Programacion_III.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    @{
        var rol = Context.Session.GetString("Rol");
    }

    <div class="sidebar">

        <div class="menu-title">
            <i class="bi bi-list"></i>
            <span>Menu</span>
        </div>

        <a asp-controller="Home" asp-action="Index">
            <span>Início</span>
            <i class="bi bi-house"></i>
        </a>

        @if (rol == "Administrador")
        {
            <a asp-controller="Usuarios" asp-action="Index">
                <span>Usuários</span>
                <i class="bi bi-person"></i>
            </a>

            <a asp-controller="Cliente" asp-action="Index">
                <span>Clientes</span>
                <i class="bi bi-people"></i>
            </a>

            <a asp-controller="Servicos" asp-action="Index">
                <span>Serviços</span>
                <i class="bi bi-tools"></i>
            </a>

            <a asp-controller="Agendamentos" asp-action="Index">
                <span>Agenda</span>
                <i class="bi bi-calendar"></i>
            </a>
        }

        @if (rol == "Usuario")
        {
            <a asp-controller="Agendamentos" asp-action="Index">
                <span>Agenda</span>
                <i class="bi bi-calendar"></i>
            </a>

            <a asp-controller="Cliente" asp-action="Index">
                <span>Clientes</span>
                <i class="bi bi-people"></i>
            </a>
        }

    </div>

    <div class="content">

        <div class="container content-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Proyecto_Programacion_III - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>



