@model Proyecto_Programacion_III.Models.Entidades.Veiculo

<style>
    body {
        background: #6d6d6d;
        font-family: 'Segoe UI',sans-serif;
    }

    .form-card {
        max-width: 750px;
        margin: 40px auto;
        background: #5f5f5f;
        padding: 35px;
        border-radius: 10px;
        box-shadow: 0 10px 25px rgba(0,0,0,.35);
    }

    .titulo {
        color: #fff;
        font-weight: bold;
        margin-bottom: 30px;
    }

    .form-group label {
        color: #fff;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .form-control {
        height: 46px;
        border-radius: 6px;
        border: 1px solid #cfcfcf;
        transition: .2s;
    }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 .2rem rgba(13,110,253,.25);
        }

    .botoes {
        display: flex;
        gap: 10px;
    }

    .btn {
        border-radius: 6px;
        padding: 10px 22px;
        font-weight: 600;
    }

    .btn-primary {
        background: #0d6efd;
        border: none;
    }

        .btn-primary:hover {
            background: #0b5ed7;
        }

    .btn-secondary {
        background: #6c757d;
        border: none;
    }

    .text-danger {
        font-size: .9rem;
    }
</style>

<div class="container mt-4">

    <div class="form-card">
      

        <h2 class="titulo">Editar Veículo</h2>

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="VeiculoId" />

            <div class="form-group mb-3">
                <label asp-for="ClienteId"></label>

                <select asp-for="ClienteId" class="form-control">

                    <option value="">Selecione um cliente</option>

                    @foreach (var item in ViewBag.Clientes)
                    {
                        <option value="@item.ClienteId">
                            @item.NomeCompleto
                        </option>
                    }

                </select>

                <span asp-validation-for="ClienteId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Modelo"></label>
                <input asp-for="Modelo" class="form-control" />
                <span asp-validation-for="Modelo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Placa"></label>
                <input asp-for="Placa" class="form-control" />
                <span asp-validation-for="Placa" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Marca"></label>
                <input asp-for="Marca" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Cor"></label>
                <input asp-for="Cor" class="form-control" />
            </div>

            <div class="form-group mb-4">
                <label asp-for="Ano"></label>
                <input asp-for="Ano" class="form-control" />
            </div>

            <div class="botoes">

                <button type="submit" class="btn btn-primary">
                    Salvar
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>

            </div>

        </form>

    </div>

</div>