@model Proyecto_Programacion_III.Models.Entidades.Veiculo

<h1>Excluir Veículo</h1>

<h3>Tem certeza que deseja excluir este veículo?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Cliente</dt>
        <dd class="col-sm-10">@Model.Cliente.NomeCompleto</dd>

        <dt class="col-sm-2">Modelo</dt>
        <dd class="col-sm-10">@Model.Modelo</dd>

        <dt class="col-sm-2">Placa</dt>
        <dd class="col-sm-10">@Model.Placa</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="VeiculoId" />
        <button type="submit" class="btn btn-danger">Excluir</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>