@model Proyecto_Programacion_III.Models.Entidades.Veiculo

<style>
    body {
        background-color: #7b7b7b;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: white;
    }

    .delete-container {
        max-width: 700px;
        margin: 50px auto;
        background: #5e5e5e;
        border-radius: 12px;
        padding: 35px;
        box-shadow: 0 8px 20px rgba(0,0,0,.25);
    }

        .delete-container h1 {
            color: white;
            font-size: 34px;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .delete-container h3 {
            color: #f8f9fa;
            font-size: 22px;
            margin-bottom: 30px;
        }

    dl.row {
        margin-bottom: 30px;
    }

    dt {
        color: #dcdcdc;
        font-weight: 600;
        margin-bottom: 10px;
    }

    dd {
        color: white;
        margin-bottom: 10px;
    }

    .btn {
        border-radius: 8px;
        font-weight: 500;
        transition: .2s;
        margin-right: 8px;
    }

        .btn:hover {
            transform: translateY(-2px);
        }

    .btn-danger {
        background: #dc3545;
        border: none;
    }

        .btn-danger:hover {
            background: #bb2d3b;
        }

    .btn-secondary {
        background: #6c757d;
        border: none;
        color: white;
    }

        .btn-secondary:hover {
            background: #5c636a;
        }
</style>

<div class="delete-container">

    <h1>Excluir Veículo</h1>

    <h3>Tem certeza que deseja excluir este veículo?</h3>

    <dl class="row">
        <dt class="col-sm-3">Cliente</dt>
        <dd class="col-sm-9">@Model.Cliente.NomeCompleto</dd>

        <dt class="col-sm-3">Modelo</dt>
        <dd class="col-sm-9">@Model.Modelo</dd>

        <dt class="col-sm-3">Placa</dt>
        <dd class="col-sm-9">@Model.Placa</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="VeiculoId" />

        <button type="submit" class="btn btn-danger">
            Excluir
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancelar
        </a>
    </form>

</div>