@model Proyecto_Programacion_III.Models.Entidades.Agendamentos
@using Proyecto_Programacion_III.Models.Entidades.Opciones

<h2>Editar Agendamentos</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="All" class="text-danger"></div>


    <select asp-for="ClienteId" class="form-control">
        <option disabled value="">-- Seleccione Cliente --</option>
        @foreach (var item in ViewBag.Clientes)
        {
            <option value="@item.ClienteId"
                    selected="@(item.ClienteId == Model.ClienteId)">
                @item.NomeCompleto
            </option>
        }
    </select>
    <span asp-validation-for="ClienteId" class="text-danger"></span>


    <select asp-for="ServicosId" class="form-control">
        <option disabled value="">-- Seleccione Servicos --</option>
        @foreach (var item in ViewBag.Servicoss)
        {
            <option value="@item.ServicosId"
                    selected="@(item.ServicosId == Model.ServicosId)">
                @item.Nome
            </option>
        }
    </select>
    <span asp-validation-for="ServicosId" class="text-danger"></span>


    <select asp-for="UsuarioId" class="form-control">
        <option disabled value="">-- Seleccione Usuario --</option>
        @foreach (var item in ViewBag.Usuarios)
        {
            <option value="@item.Id"
                    selected="@(item.Id == Model.UsuarioId)">
                @item.Nome
            </option>
        }
    </select>
    <span asp-validation-for="UsuarioId" class="text-danger"></span>


    <input asp-for="FechaHora" type="datetime-local" class="form-control" />
    <span asp-validation-for="FechaHora" class="text-danger"></span>

    <br />

    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}