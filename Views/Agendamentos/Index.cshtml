@model IEnumerable<Proyecto_Programacion_III.Models.Entidades.Agendamentos>
@using Proyecto_Programacion_III.Models.Entidades.Opciones

<style>
    body {
        background-color: #7b7b7b;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: white;
    }

    .agendamentos-container {
        margin: 40px auto;
        padding: 0;
    }

    h2 {
        margin-bottom: 25px;
        font-size: 34px;
        font-weight: 600;
        color: white;
    }

    .table {
        background: #5e5e5e;
        border-radius: 10px;
        overflow: hidden;
        border: none;
        box-shadow: 0 8px 20px rgba(0,0,0,.25);
    }

        .table thead {
            background: #3d3d3d;
        }

            .table thead th {
                color: white;
                padding: 15px;
                border: none;
                text-transform: uppercase;
                letter-spacing: 1px;
                font-size: 14px;
            }

        .table tbody td {
            padding: 15px;
            color: white;
            border-top: 1px solid #777;
            vertical-align: middle;
        }

        .table tbody tr {
            transition: .25s;
        }

            .table tbody tr:hover {
                background: #6c6c6c;
            }

    .btn {
        border-radius: 8px;
        font-weight: 500;
        transition: .2s;
        margin-right: 5px;
        margin-bottom: 5px;
    }

    .btn-primary {
        background: #0d6efd;
        border: none;
        color: white;
    }

        .btn-primary:hover {
            background: #0b5ed7;
            transform: translateY(-2px);
        }

    .btn-warning {
        background: #ffc107;
        color: black;
        border: none;
    }

        .btn-warning:hover {
            background: #e0a800;
        }

    .btn-danger {
        background: #dc3545;
        color: white;
        border: none;
    }

        .btn-danger:hover {
            background: #bb2d3b;
        }

    .status-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .status-programada {
        background: #0d6efd;
        color: white;
    }

    .status-cancelada {
        background: #dc3545;
        color: white;
    }

    .status-finalizada {
        background: #198754;
        color: white;
    }
</style>

<div class="agendamentos-container">
    <h2>Lista de Agendamentos</h2>
    <a asp-action="Create" class="btn btn-primary">Agendar Serviço</a>
    <a asp-action="CreatePersonalizado" class="btn btn-primary">Serviço Personalizado</a>

    <table class="table">
        <thead>
            <tr>
                <th>Cliente</th>
                <th>Servicos</th>
                <th>Data</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Cliente?.NomeCompleto</td>
                    <td>@item.Servicos?.Nome</td>
                    <td>@item.Data</td>
                    <td>
                        @{
                            var badgeClass = item.Estado == EstadoAgendamentos.Cancelada
                            ? "status-cancelada"
                            : item.Estado == EstadoAgendamentos.Finalizada
                            ? "status-finalizada"
                            : "status-programada";
                        }
                        <span class="status-badge @badgeClass">@item.Estado</span>
                    </td>
                    <td>
                        @if (User.IsInRole("Administrador"))
                        {
                            @if (item.Estado != EstadoAgendamentos.Cancelada)
                            {
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">Detalhes</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary">Editar</a>
                                <a asp-action="Cancelar" asp-route-id="@item.Id" class="btn btn-danger">Cancelar</a>
                            }
                            else
                            {
                                <span class="text-danger">Cancelada</span>
                            }

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Eliminar</a>
                        }

                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
