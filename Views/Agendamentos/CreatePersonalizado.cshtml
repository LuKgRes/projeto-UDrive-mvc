@model Proyecto_Programacion_III.Models.Entidades.AgendamentoPersonalizado

<style>
    .agendamento-container {
        max-width: 900px;
        margin: 30px auto;
        background: #3f3f3f;
        padding: 35px;
        border-radius: 14px;
        box-shadow: 0 8px 20px rgba(0,0,0,.35);
    }

        .agendamento-container h2 {
            color: white;
            font-size: 34px;
            font-weight: bold;
            margin-bottom: 25px;
        }

        .agendamento-container h5 {
            color: #f1f1f1;
            font-weight: 600;
            margin-top: 20px;
            margin-bottom: 8px;
        }

        .agendamento-container label {
            color: white;
            font-weight: 600;
        }

        .agendamento-container .form-control {
            background: #5f5f5f;
            border: 1px solid #727272;
            color: white;
            border-radius: 8px;
            padding: 10px;
        }

            .agendamento-container .form-control:focus {
                background: #696969;
                color: white;
                border-color: #2AB5E4;
                box-shadow: 0 0 0 .2rem rgba(42,181,228,.25);
            }

            .agendamento-container .form-control option {
                background: #5f5f5f;
                color: white;
            }

        .agendamento-container textarea.form-control {
            min-height: 120px;
            resize: vertical;
        }

    #novoVeiculoFields {
        margin-top: 20px;
        padding: 20px;
        background: #4c4c4c;
        border-radius: 10px;
    }

        #novoVeiculoFields h5 {
            margin-top: 0;
        }

    .botoes-formulario {
        display: flex;
        gap: 12px;
        margin-top: 30px;
    }

        .botoes-formulario .btn {
            border-radius: 8px;
            padding: 10px 24px;
            font-weight: 600;
        }

    .btn-primary {
        background: #0d6efd;
        border: none;
    }

        .btn-primary:hover {
            background: #0b5ed7;
        }

    .btn-secondary {
        background: #6c757d;
        border: none;
    }

        .btn-secondary:hover {
            background: #5c636a;
        }
</style>

<div class="agendamento-container">
    <form asp-action="CreatePersonalizado" method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <h2>Serviço Personalizado</h2>

        <h5>Selecione cliente</h5>
        <select asp-for="ClienteId" class="form-control" required>
            <option disabled selected value="">-- Selecione um cliente --</option>
            @foreach (var item in ViewBag.Clientes)
            {
                <option value="@item.ClienteId">@item.NomeCompleto</option>
            }
        </select>
        <span asp-validation-for="ClienteId" class="text-danger"></span>

        <h5>Selecione o veículo</h5>
        <select id="veiculoSelect" name="VeiculoSelecionado" class="form-control">
            <option value="" selected>-- Selecione um veículo --</option>
            @foreach (var item in ViewBag.Veiculos)
            {
                <option value="@item.VeiculoId">@item.Modelo - @item.Placa</option>
            }
            <option value="novo">+ Cadastrar novo veículo</option>
        </select>
        <span id="veiculoValidationSpan" class="text-danger"></span>

        <div id="novoVeiculoFields" style="display:none;">
            <h5>Dados do novo veículo</h5>

            <label>Modelo</label>
            <input name="NovoVeiculoModelo" class="form-control" />

            <label>Placa</label>
            <input name="NovoVeiculoPlaca" class="form-control" />

            <label>Marca</label>
            <input name="NovoVeiculoMarca" class="form-control" />

            <label>Cor</label>
            <input name="NovoVeiculoCor" class="form-control" />

            <label>Ano</label>
            <input name="NovoVeiculoAno" class="form-control" type="number" />
        </div>

        <h5>Descrição</h5>
        <textarea asp-for="ServicoDescricao" class="form-control" placeholder="Descreva o problema ou o serviço a ser feito"></textarea>
        <span asp-validation-for="ServicoDescricao" class="text-danger"></span>

        <h5>Selecione uma data</h5>
        <input asp-for="Data" type="datetime-local" class="form-control" />
        <span asp-validation-for="Data" class="text-danger"></span>

        <br />
        <div class="botoes-formulario">
            <button type="submit" class="btn btn-primary">
                Guardar
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Voltar
            </a>
        </div>
    </form>
</div>

<script>
    const veiculoSelect = document.getElementById('veiculoSelect');
    const novoVeiculoFields = document.getElementById('novoVeiculoFields');
    veiculoSelect.addEventListener('change', function () {
        novoVeiculoFields.style.display = this.value === 'novo' ? 'block' : 'none';
    });
</script>