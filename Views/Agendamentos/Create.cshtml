@model Proyecto_Programacion_III.Models.Entidades.Agendamentos

<style>
    .agendamento-container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        padding: 32px 40px;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
    }

    .agendamento-container h2 {
        font-size: 1.6rem;
        font-weight: 600;
        color: #1e1e2f;
        margin-bottom: 24px;
    }

    .agendamento-container h5 {
        font-size: 0.9rem;
        font-weight: 500;
        color: #444;
        margin-bottom: 8px;
        margin-top: 20px;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        background-color: #fafafa;
    }

    .form-control:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        background-color: #fff;
    }

    .text-danger {
        font-size: 0.8rem;
        color: #dc2626;
    }

    .btn-primary {
        margin-top: 28px;
        padding: 10px 28px;
        background-color: #2563eb;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s, transform 0.1s;
    }

    .btn-primary:hover {
        background-color: #1d4ed8;
    }

    .btn-primary:active {
        transform: scale(0.98);
    }
</style>

<div class="agendamento-container">
    <form asp-action="Create" method="post">
        <h2>Agendamento de serviço</h2>

        <h5>Seleccione cliente</h5>
        <select asp-for="ClienteId" class="form-control" required>
            <option disabled selected value="">-- Selecione um cliente --</option>
            @foreach (var item in ViewBag.Clientes)
            {
                <option value="@item.ClienteId">@item.NomeCompleto</option>
            }
        </select>
        <span asp-validation-for="ClienteId" class="text-danger"></span>

        <h5>Seleccione Servicos</h5>
        <select asp-for="ServicosId" class="form-control" required>
            <option disabled selected value="">-- Selecione um serviço --</option>
            @foreach (var item in ViewBag.Servicos)
            {
                <option value="@item.ServicosId">@item.Nome</option>
            }
        </select>
        <span asp-validation-for="ServicosId" class="text-danger"></span>

        <h5>Selecione uma data</h5>
        <input asp-for="Data" type="datetime-local" class="form-control" />
        <span asp-validation-for="Data" class="text-danger"></span>

        <br />
        <button type="submit" class="btn-primary">guardar</button>
        <a asp-action="Index" class="btn btn-primary">Voltar</a>
    </form>
</div>