@model Proyecto_Programacion_III.Models.Entidades.Agendamentos

<style>
    .card-form {
        max-width: 850px;
        margin: 30px auto;
        background: #3f3f3f;
        border-radius: 14px;
        box-shadow: 0 10px 25px rgba(0,0,0,.35);
        padding: 35px;
    }

    .titulo-pagina {
        color: #fff;
        font-size: 38px;
        font-weight: 700;
        margin-bottom: 30px;
    }

    .subtitulo {
        color: #fff;
        margin: 25px 0 15px;
    }

    .form-dark label {
        color: #fff;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .form-control {
        background: #5e5e5e;
        border: 1px solid #6d6d6d;
        color: white;
        border-radius: 8px;
        height: 46px;
    }

        .form-control:focus {
            background: #666;
            color: white;
            border-color: #2AB5E4;
            box-shadow: 0 0 0 .2rem rgba(42,181,228,.25);
        }

        .form-control option {
            background: #5e5e5e;
            color: white;
        }

    .botoes {
        display: flex;
        gap: 12px;
        margin-top: 30px;
    }

    .btn-primary {
        background: #2AB5E4;
        border: none;
        border-radius: 8px;
        padding: 10px 28px;
        font-weight: 600;
    }

        .btn-primary:hover {
            background: #1d9fc9;
        }

    .btn-secondary {
        background: #6b6b6b;
        border: none;
        border-radius: 8px;
        padding: 10px 28px;
    }

        .btn-secondary:hover {
            background: #5a5a5a;
        }

    #novoVeiculoFields {
        margin: 25px 0;
        padding: 20px;
        background: #4b4b4b;
        border-radius: 10px;
    }
</style>

<div class="container py-4">
    <div class="card-form">

        <h2 class="titulo-pagina">Agendamento de Serviço</h2>

        <form asp-action="Create" method="post" class="form-dark">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label>Selecione o cliente</label>

                <select asp-for="ClienteId" class="form-control">
                    <option disabled selected value="">-- Selecione um cliente --</option>
                    @foreach (var item in ViewBag.Clientes)
                    {
                        <option value="@item.ClienteId">@item.NomeCompleto</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label>Selecione o veículo</label>

                <select id="veiculoSelect"
                        name="VeiculoSelecionado"
                        class="form-control">

                    <option value="">-- Selecione um veículo --</option>

                    @foreach (var item in ViewBag.Veiculos)
                    {
                        <option value="@item.VeiculoId">
                            @item.Modelo - @item.Placa
                        </option>
                    }

                    <option value="novo">
                        + Cadastrar novo veículo
                    </option>

                </select>
            </div>

            <div id="novoVeiculoFields" style="display:none">

                <h4 class="subtitulo">Novo veículo</h4>

                <input name="NovoVeiculoModelo" class="form-control mb-2" placeholder="Modelo">

                <input name="NovoVeiculoPlaca" class="form-control mb-2" placeholder="Placa">

                <input name="NovoVeiculoMarca" class="form-control mb-2" placeholder="Marca">

                <input name="NovoVeiculoCor" class="form-control mb-2" placeholder="Cor">

                <input name="NovoVeiculoAno" class="form-control" type="number" placeholder="Ano">

            </div>

            <div class="mb-3">
                <label>Selecione o serviço</label>

                <select asp-for="ServicosId" class="form-control">

                    <option disabled selected value="">
                        -- Selecione um serviço --
                    </option>

                    @foreach (var item in ViewBag.Servicos)
                    {
                        <option value="@item.ServicosId">@item.Nome</option>
                    }

                </select>
            </div>

            <div class="mb-4">
                <label>Data do agendamento</label>

                <input asp-for="Data"
                       type="datetime-local"
                       class="form-control" />
            </div>

            <div class="botoes">

                <button class="btn btn-primary">
                    Salvar
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Voltar
                </a>

            </div>

        </form>

    </div>
</div>

<script>
    const veiculoSelect = document.getElementById('veiculoSelect');
    const novoVeiculoFields = document.getElementById('novoVeiculoFields');

    veiculoSelect.addEventListener('change', function () {
        novoVeiculoFields.style.display = this.value === 'novo' ? 'block' : 'none';
    });
</script>
