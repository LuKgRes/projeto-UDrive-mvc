@model Proyecto_Programacion_III.Models.Entidades.Servicos

@{
    ViewData["Title"] = "Editar Servicos";
}

<h2>Editar Servicos</h2>

<form asp-action="Edit" method="post">
    
    <input type="hidden" asp-for="ServicosId" />

    <div class="form-group">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Descrição</label>
        <input asp-for="Descricao" class="form-control" />
    </div>

    <div class="form-group">
        <label>Data</label>
        <input asp-for="Data" class="form-control" />
        <span asp-validation-for="Data" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Valor</label>
        <input asp-for="Valor" class="form-control" />
        <span asp-validation-for="Valor" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Estado</label>
        <select asp-for="Estado" class="form-control"
                asp-items="Html.GetEnumSelectList<Proyecto_Programacion_III.Models.Entidades.Opciones.EstadoServicos>()">
        </select>
    </div>

    <br />

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
