<br />
<br />
<h2>Dashboard Administrador</h2>
<br />
<br />

    <div class="row">

        <div class="col-md-3">
            <div class="card bg-primary text-white p-3">
                <h5>Usuarios</h5>
                <h2>@ViewBag.TotalUsuarios</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-primary text-white p-3">
                <h5>Clientes</h5>
                <h2>@ViewBag.TotalClientes</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-primary text-white p-3">
                <h5>Agendamentos</h5>
                <h2>@ViewBag.TotalAgendamentos</h2>
            </div>
        </div>
    </div>

    <div class="row mt-3">

        <div class="col-md-3">
            <div class="card bg-success text-white p-3">
                <h5>Servicoss Activos</h5>
                <h2>@ViewBag.ServicossActivos</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-danger text-white p-3">
                <h5>Servicoss Inactivos</h5>
                <h2>@ViewBag.ServicossInactivos</h2>
            </div>
        </div>

    </div>

    <div class="row mt-3">

        <div class="col-md-3">
            <div class="card bg-success text-white p-3">
                <h5>Programadas</h5>
                <h2>@ViewBag.AgendamentosProgramadas</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-secondary text-white p-3">
                <h5>Canceladas</h5>
                <h2>@ViewBag.AgendamentosCanceladas</h2>
            </div>
        </div>
    </div>

<br />

    <div class="mt-4">
        <h4>Top 3 Servicoss</h4>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Servicos</th>
                    <th>Cantidad</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ViewBag.TopServicoss)
                {
                    <tr>
                        <td>@item.Servicos</td>
                        <td>@item.Total</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
