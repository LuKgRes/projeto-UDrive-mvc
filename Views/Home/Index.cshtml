@{
    ViewData["Title"] = "Home Page";
    var rol = Context.Session.GetString("Rol");
}
<br />
<div class="text-center">
    <h1 class="display-4">Bem-vindo ao sistema de Agendamentos</h1>
</div>
<br />
<br />

<div class="text-center mb-4">
    <p><strong>Perfil atual:</strong> @rol</p>
</div>
<div class="d-flex justify-content-center gap-3">
    <a asp-action="LoginAdmin" class="btn btn-primary">
        Administrador
    </a>
    <a asp-action="LoginUsuario" class="btn btn-primary">
        Cliente
    </a>
</div>
<br />
<br />