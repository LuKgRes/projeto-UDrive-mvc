@{
    ViewData["Title"] = "Home Page";
}

<br />
<style>
    :root {
        --bg: #808080;
        --card: #5f5f5f;
        --header: #3d3d3d;
        --primary: #0d6efd;
        --primary-hover: #0b5ed7;
        --danger: #dc3545;
        --text: #ffffff;
        --text-secondary: #d8d8d8;
    }

    body {
        margin: 0;
        background: var(--bg);
        font-family: 'Segoe UI',sans-serif;
    }

    .home-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .home-card {
        width: 600px;
        background: var(--card);
        color: white;
        border-radius: 12px;
        padding: 45px;
        box-shadow: 0 8px 20px rgba(0,0,0,.25);
        text-align: center;
    }

        .home-card h1 {
            font-size: 42px;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .home-card p {
            color: var(--text-secondary);
            font-size: 18px;
        }

        .home-card hr {
            border-color: #777;
        }

    .perfil {
        display: inline-block;
        margin: 20px 0;
        padding: 10px 20px;
        background: var(--header);
        border-radius: 8px;
        font-size: 18px;
        color: white;
    }

    .botoes {
        margin-top: 30px;
    }

        .botoes .btn {
            width: 180px;
            border-radius: 8px;
            font-weight: 600;
            margin: 5px;
        }

    .btn-primary {
        background: var(--primary);
        border: none;
    }

        .btn-primary:hover {
            background: var(--primary-hover);
        }

    .btn-secondary {
        background: #6c757d;
        border: none;
    }

    .btn-danger {
        background: var(--danger);
    }
</style>
<br />
<div class="home-container">
    <div class="home-card">
        @if (User.Identity.IsAuthenticated)
        {
            <h1>Bem-vindo ao UDrive</h1>
            <p>Perfil atual:</p>
            <div class="perfil"> <span> @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value </span> </div>
            <div class="botoes">
                <a asp-controller="Account" asp-action="Logout" class="btn btn-secondary">Sair</a>
            </div>
        }
        else
        {
            <h1>Bem-vindo ao UDrive</h1>
            <p>Você ainda não está logado</p>
            <div class="botoes">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Entrar</a>
                <a asp-controller="Account" asp-action="Cadastro" class="btn btn-secondary">Cadastrar</a>
            </div>
        }
    </div>
</div>